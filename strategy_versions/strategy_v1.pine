// ═══════════════════════════════════════════════════════════
// MFC Self-Improving Strategy  v1.1 (Advanced Risk & Momentum)
// Goal: Profit Factor > 1.3, Max Drawdown < 15%, Sharpe > 1.5
// BTC/USDT  |  4H chart recommended  |  Pine Script v5
//
// HOW TO USE:
// 1. Open TradingView → Pine Editor → paste this → Add to Chart
// 2. Click "Strategy Tester" to view the historical performance.
// 3. To get 150+ trades, use Deep Backtesting (Premium) or test on a smaller timeframe (1H) to see statistical proof.
// 4. Create an alert → Message: {{strategy.order.alert_message}}
//    Webhook URL: http://YOUR_PC_IP:5000/trade   (Python logger)
// ═══════════════════════════════════════════════════════════

//@version=5
strategy(
    title             = "MFC Advanced Institutional v1.1",
    shorttitle        = "MFC Adv 1.1",
    overlay           = true,
    default_qty_type  = strategy.percent_of_equity,
    default_qty_value = 50,
    initial_capital   = 1000,
    commission_type   = strategy.commission.percent,
    commission_value  = 0.1,
    slippage          = 2,
    pyramiding        = 0
)

// ── INPUTS ───────────────────────────────────────────────────
grp_trend = "Macro Trend Filter"
grp_mom   = "Momentum & Entry"
grp_risk  = "Risk Management (Crucial for <15% DD)"

ema_macro  = input.int  (200,  "Macro Trend EMA",   minval=50,  maxval=500, group=grp_trend)
ema_fast   = input.int  (12,   "Fast EMA",          minval=3,   maxval=50,  group=grp_mom)
ema_slow   = input.int  (26,   "Slow EMA",          minval=10,  maxval=200, group=grp_mom)

rsi_len    = input.int  (14,   "RSI length",        minval=2,   maxval=30,  group=grp_mom)
rsi_ob     = input.int  (70,   "RSI Overbought",    minval=55,  maxval=80,  group=grp_mom)
rsi_os     = input.int  (30,   "RSI Oversold",      minval=20,  maxval=45,  group=grp_mom)

atr_len    = input.int  (14,   "ATR length",        minval=5,   maxval=30,  group=grp_risk)
sl_atr     = input.float(1.5,  "Initial SL (ATR)",  minval=0.5, maxval=5.0,  step=0.1, group=grp_risk)
tp_atr     = input.float(3.0,  "Take Profit (ATR)", minval=1.0, maxval=15.0, step=0.1, group=grp_risk)
use_trail  = input.bool (true, "Use Trailing Stop", group=grp_risk, tooltip="Trails stop to lock in profits, boosting Sharpe Ratio.")
trail_atr  = input.float(1.5,  "Trailing SL (ATR)", minval=0.5, maxval=5.0,  step=0.1, group=grp_risk)

// ── INDICATORS ───────────────────────────────────────────────
macro_t = ta.ema(close, ema_macro)
ema_f   = ta.ema(close, ema_fast)
ema_s   = ta.ema(close, ema_slow)
rsi     = ta.rsi(close, rsi_len)
atr     = ta.atr(atr_len)

// ── CONDITIONS ───────────────────────────────────────────────
// Trend filter ensures we only trade with the institutional macro flow.
trend_up   = close > macro_t
trend_down = close < macro_t

cross_up   = ta.crossover(ema_f, ema_s)
cross_down = ta.crossunder(ema_f, ema_s)

// Momentum filter: Avoid entering longs when RSI is overbought, or shorts when oversold.
long_entry  = cross_up   and trend_up   and rsi < rsi_ob
short_entry = cross_down and trend_down and rsi > rsi_os

// ── STATE VARIABLES FOR DYNAMIC SL / TP ──────────────────────
var float trade_sl = na
var float trade_tp = na

if long_entry and strategy.position_size == 0
    trade_sl := close - atr * sl_atr
    trade_tp := close + atr * tp_atr

if short_entry and strategy.position_size == 0
    trade_sl := close + atr * sl_atr
    trade_tp := close - atr * tp_atr

// Trailing stop logic: Moves stop loss in direction of profit to lock it in
if strategy.position_size > 0 and use_trail
    trade_sl := math.max(trade_sl, close - atr * trail_atr)

if strategy.position_size < 0 and use_trail
    trade_sl := math.min(trade_sl, close + atr * trail_atr)

// ── ENTRIES ──────────────────────────────────────────────────
if long_entry and strategy.position_size == 0
    strategy.entry("Long", strategy.long,
        alert_message = '{"side":"long","price":' + str.tostring(close) + ',"sl":' + str.tostring(math.round(trade_sl, 2)) + ',"tp":' + str.tostring(math.round(trade_tp, 2)) + ',"atr":' + str.tostring(math.round(atr, 2)) + ',"rsi":' + str.tostring(math.round(rsi, 1)) + ',"event":"entry"}')

if short_entry and strategy.position_size == 0
    strategy.entry("Short", strategy.short,
        alert_message = '{"side":"short","price":' + str.tostring(close) + ',"sl":' + str.tostring(math.round(trade_sl, 2)) + ',"tp":' + str.tostring(math.round(trade_tp, 2)) + ',"atr":' + str.tostring(math.round(atr, 2)) + ',"rsi":' + str.tostring(math.round(rsi, 1)) + ',"event":"entry"}')

// ── EXITS ────────────────────────────────────────────────────
if strategy.position_size > 0
    strategy.exit("Exit Long", "Long", stop=trade_sl, limit=trade_tp, alert_message='{"event":"exit","side":"long","reason":"sl_or_tp"}')

if strategy.position_size < 0
    strategy.exit("Exit Short", "Short", stop=trade_sl, limit=trade_tp, alert_message='{"event":"exit","side":"short","reason":"sl_or_tp"}')

// ── PLOTS ────────────────────────────────────────────────────
plot(macro_t, "Macro Trend", color=color.new(color.white, 30), linewidth=2)
plot(ema_f,   "Fast EMA",    color=color.new(color.aqua, 0),   linewidth=1)
plot(ema_s,   "Slow EMA",    color=color.new(color.orange, 0), linewidth=1)

sl_plot = strategy.position_size != 0 ? trade_sl : na
tp_plot = strategy.position_size != 0 ? trade_tp : na

plot(sl_plot, "Trailing SL", color=color.new(color.red, 0),   style=plot.style_linebr, linewidth=1)
plot(tp_plot, "Take Profit", color=color.new(color.green, 0), style=plot.style_linebr, linewidth=1)

plotshape(long_entry,  "Long",  location=location.belowbar, style=shape.triangleup,   color=color.lime, size=size.small)
plotshape(short_entry, "Short", location=location.abovebar, style=shape.triangledown, color=color.red,  size=size.small)

bgcolor(trend_up   ? color.new(color.green, 95) : na)
bgcolor(trend_down ? color.new(color.red, 95)   : na)
